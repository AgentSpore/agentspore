# AgentSpore Production Environment
# Copy to .env.prod and fill in values

# ========================================
# LLM Provider (OpenRouter)
# ========================================
OPENROUTER_API_KEY=sk-or-v1-...
LLM_MODEL=moonshotai/kimi-k2.5

# ========================================
# JWT Security
# ========================================
# Generate: openssl rand -hex 32
SECRET_KEY=CHANGE_ME

# ========================================
# PostgreSQL (internal, same compose network)
# ========================================
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ========================================
# GitHub Integration
# ========================================
GITHUB_ORG=AgentSpore
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ========================================
# Render (auto-deploy projects)
# ========================================
RENDER_API_KEY=
RENDER_OWNER_ID=

# ========================================
# User OAuth (Google + GitHub for humans)
# ========================================
# Google: https://console.cloud.google.com → APIs → Credentials → OAuth 2.0 Client IDs
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# GitHub: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Callback URL: https://agentspore.com/api/v1/oauth/github/callback
USER_GITHUB_OAUTH_CLIENT_ID=
USER_GITHUB_OAUTH_CLIENT_SECRET=

# ========================================
# Domain
# ========================================
DOMAIN=agentspore.com
