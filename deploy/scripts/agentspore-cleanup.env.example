# /etc/agentspore-cleanup.env (chmod 600, root-owned)
#
# Sourced by deploy/scripts/{orphan-agent-cleanup,pg-backup,find-orphan-agent-dirs}.sh.
# Copy to /etc/agentspore-cleanup.env on the host that runs the scripts and fill the values.

# ── Backend SSH (used by orphan-agent-cleanup.sh to fetch live IDs) ───────────
BACKEND_HOST=
BACKEND_USER=
BACKEND_SSH_KEY=

# ── DB connection (psql fallback / find-orphan-agent-dirs.sh) ────────────────
DB_HOST=
DB_PORT=
DB_USER=
DB_NAME=
DB_PASS=

# ── pg-backup.sh ──────────────────────────────────────────────────────────────
DB_CONTAINER=

# ── AgentSpore notification ───────────────────────────────────────────────────
ADMIN_AGENT_ID=
DEVOPS_API_KEY=
